<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AndroClaw" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Theme.AndroClaw.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FF0F0F1A</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.AndroClaw</item>
    </style>
</resources>
