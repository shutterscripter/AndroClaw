<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AndroClaw" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/purple_dark</item>
        <item name="android:navigationBarColor">@color/purple_dark</item>
    </style>

    <style name="Theme.AndroClaw.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/purple_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.AndroClaw</item>
    </style>
</resources>
